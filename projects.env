[base]
online=
offline=
# Default is the project name, so this is not necessary
subdir=base
# Custom provisioner script in base
provision=baseProvision.sh
version=1.0

[cheatsheets]
online=
offline=cheatsheets.zip
# DEFAULT is the default for provisioners, don't need to specify it here
provision=DEFAULT
# Make a subdirectory "cheatsheets" and extract there
# Default is false, extract assuming the archive has the subdirectory included
subdir=true
version=1.0

[cyberchef]
online.type=git
online=https://github.com/gchq/CyberChef.git
offline=CyberChef_6a3a370bb15032dbfd1a063af446837b572464f1.zip
# Don't need to specify a provisioner script, it will use the default for the file type (zip)
# This will unzip the file if offline into "cyberchef" subdir, or git clone into cyberchef if online
# As well as save the install date in INSTALLED.txt
version=11.0.0

[scapy]
online.type=git
online=https://github.com/secdev/scapy.git
offline=scapy-master.zip
# Additional setup via powershell, here to install dependencies in windows python
powershell=provision.ps1
# Also in WSL to run make on docs
provision=provision.sh
version=2.5.0.dev216

[binwalk]
online.type=git
online=https://github.com/ReFirmLabs/binwalk
offline=binwalk-3.1.0.tar.gz
version=3.1.0

[bucketfinder]
online.type=wget
online=https://digi.ninja/files/bucket_finder_1.1.tar.bz2
offline=bucket_finder_1.1.tar.bz2
subdir=true
version=1.1

[enum]
online.type=git
online=https://github.com/CiscoCXSecurity/enum4linux
offline=enum4linux.tar.gz
version=0.9.1

[exiftool]
online.type=git
online=https://github.com/exiftool/exiftool
offline=exiftool-master.zip
version=13.58

[ffuf]
online.type=git
online=https://github.com/ffuf/ffuf.git
offline=ffuf-main.zip
provision=provision.sh
version=2.1.0

[ghidra]
offline=ghidra_12.1.2_PUBLIC_20260605.zip
version=12.1.2

[hash_extender]
online.type=git
online=https://github.com/iagox86/hash_extender
offline=hash_extender-master.zip
provision=MAKE
renameFrom=hash_extender-master
version=1.0

[jefferson]
online.type=git
online=https://github.com/onekey-sec/jefferson.git
offline=jefferson-master.zip
provision=provision.sh
version=0.4.7

[jwt_tool]
online.type=git
online=https://github.com/ticarpi/jwt_tool.git
offline=jwt_tool-main.zip
provision=provision.sh
version=2.3.0

[mallard]
online.type=git
online=https://github.com/dagonis/Mallard
offline=Mallard-main.zip
version=1.0

[payloads]
online.type=git
online=https://github.com/swisskyrepo/PayloadsAllTheThings.git
offline=PayloadsAllTheThings-master.zip
version=1.0

[sqlmap]
online.type=git
online=https://github.com/sqlmapproject/sqlmap.git
offline=sqlmap-master.zip
version=1.0

[sulley]
online.type=git
online=https://github.com/jtpereyda/boofuzz
offline=boofuzz-master.zip
provision=provision.sh
version=0.4.2

[suricata]
online.type=wget
online=https://www.openinfosecfoundation.org/download/suricata-8.0.5.tar.gz
offline=suricata-8.0.5.tar.gz
renameFrom=suricata-8.0.5
version=8.0.5

[trufflehog]
online.type=git
online=https://github.com/trufflesecurity/trufflehog.git
offline=trufflehog-main.zip
provision=provision.sh
version=3.95.5

[pycdc]
online.type=git
online=https://github.com/zrax/pycdc
offline=pycdc-master.zip
provision=provision.sh
version=1.0